{
  "version": 2,
  "routes": [
    {
      "src": "/verify",
      "dest": "/verify.html"
    },
    {
      "src": "/verify.html",
      "dest": "/verify.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
